@model EnvoiceProject.Models.EnvoiceDTO
<!-- Bootstrap 5 CDN -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"
      crossorigin="anonymous">
<style>
    .text-info {
        color: #169cb7 !important;
    }
</style>
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-12 col-md-11">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-body p-5">
                    <div class="text-center mb-1">
                        <h3 class="fw-bold text-info mb-1">Invoice Preparattion</h3>
                    </div>
                    <form asp-action="Create" method="post">
                        <div class="row">
                            <div class="d-flex justify-content-end mb-4 gap-2">
                                <button type="submit" class="bg-info bt-xs btn-info " style="padding:4px 20px;border-radius:4px">Submit</button>
                                <button type="reset"class="bg-info bt-xs btn-info "style="padding:4px 20px;border-radius:4px">Clear</button>
                            </div>
                            <!-- Left Section: Supplier/Item Details -->
                            <div class="col-md-8">
                                <div class="card mb-3">
                                    <div class="card-header bg-info bg-opacity-25 fw-bold">Voucher Data</div>
                                    <div class="card-body p-3">
                                        <div class="row mb-2">
                                            <div class="col-md-2">
                                                <label class="form-label">Customer</label>
                                            </div>
                                            <div class="col-md-8">
                                                <select asp-for="CustomerId" class="form-select form-select-sm">
                                                    <option value="1">John Doe - 555-1234 - 123 Main St</option>
                                                    <option value="2">Jane Smith - 555-5678 - 456 Oak Ave</option>
                                                    <option value="3">Acme Corp - 555-9999 - 789 Industrial Rd</option>
                                                </select>
                                            </div>
                                        </div>
                                        <div class="row mb-2">
                                            <div class="col-md-2">
                                                <label class="form-label">Type</label>
                                            </div>
                                            <div class="col-md-8">
                                                <select asp-for="InvoiceType" class="form-select form-select-sm">
                                                    <option value="1">Cash Invoice</option>
                                                    <option value="2">Credit Invoice</option>
                                                    <option value="3">Debit Invoice</option>
                                                    <option value="4">Return Invoice</option>
                                                    <option value="5">Refund Invoice</option>
                                                    <option value="6">General Invoice</option>
                                                </select>
                                            </div>
                                        </div>
                                        <div class="row mb-2">
                                            <div class="col-md-2">
                                                <label class="form-label">Item</label>
                                            </div>
                                            <div class="col-md-8">
                                                <select asp-for="CustomerId" class="form-select form-select-sm">
                                                    <option value="1">Item 1</option>
                                                    <option value="2">Item 2</option>
                                                    <option value="3">Item 3</option>
                                                </select>
                                            </div>
                                            <div class="col-md-2">
                                                <button class="bg-info bt-xs btn-info w-100" style="padding:3px 10px;border-radius:4px">Add Item</button>
                                            </div>
                                        </div>
                                        <div class="row mb-2">
                                               <div class="col-md-2">
                                              <label class="form-label">Qty</label>
                                            </div>
                                            <div class="col-md-4">
                                            
                                                <input asp-for="qty" type="number" step="0.01" class="form-control form-control-sm" placeholder="Qty" />
                                            </div>
                                                <div class="col-md-2">
                                              <label class="form-label">Price</label>
                                            </div>
                                            <div class="col-md-4">
                                                <input asp-for="price" type="number" step="0.01" class="form-control form-control-sm" placeholder="Price" />
                                            </div>
                                        </div>

                                    </div>
                                </div>
                                <div class="card mb-3">
                                    <div class="card-header bg-info bg-opacity-25 fw-bold">Line Items</div>
                                    <div class="card-body p-2">
                                        <table style="width:100%" id="lineitemTable" class="table table-bordered table-sm">
                                            <thead class="bg-info bg-opacity-25">
                                                <tr>
                                                    <td>Sn</td>
                                                    <td>Art. Code</td>
                                                    <td>Art. Name</td>
                                                    <td style="text-align:right">Quantity</td>
                                                    <td style="text-align:right">Price</td>
                                                    <td style="text-align:right">Total</td>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <tr><td colspan="6" class="text-center">No data</td></tr>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                            <!-- Right Section: Voucher Info & Summary -->
                            <div class="col-md-4">
                                <div class="card mb-3">
                                    <div class="card-header bg-info bg-opacity-25 fw-bold">Voucher Info</div>
                                    <div class="card-body p-3">
                                        <div class="mb-2 row align-items-center">
                                            <div class="col-5 col-md-5">
                                                <label class="form-label mb-0">Voucher No</label>
                                            </div>
                                            <div class="col-7 col-md-7">
                                                <input asp-for="InvoiceNumber" class="form-control form-control-sm" placeholder="Number" />
                                            </div>
                                        </div>
                                        <div class="mb-2 row align-items-center">
                                            <div class="col-5 col-md-5">
                                                <label class="form-label mb-0">Date</label>
                                            </div>
                                            <div class="col-7 col-md-7">
                                                <input asp-for="InvoiceDate" type="date" class="form-control form-control-sm" />
                                            </div>
                                        </div>
                                        <div class="mb-2 row align-items-center">
                                            <div class="col-5 col-md-5">
                                                <label class="form-label mb-0">Reference</label>
                                            </div>
                                            <div class="col-7 col-md-7">
                                                <input asp-for="InvoiceReference" class="form-control form-control-sm" placeholder="Reference" />
                                            </div>
                                        </div>
                                        <div class="mb-2 row align-items-center">
                                            <div class="col-5 col-md-5">
                                                <label class="form-label mb-0">Remark</label>
                                            </div>
                                            <div class="col-7 col-md-7">
                                                <input type="text" class="form-control form-control-sm" placeholder="Remark" />
                                            </div>
                                        </div>
                                        <div class="mb-2 row align-items-center">
                                            <div class="col-5 col-md-5">
                                                <label class="form-label mb-0">Payment Info</label>
                                            </div>
                                            <div class="col-7 col-md-7">
                                                <input type="text" class="form-control form-control-sm" placeholder="Payment Info" />
                                            </div>
                                        </div>
                                   <div class="mb-2 row align-items-center">
                                        <div class="col-5 col-md-5">
                                                <label class="form-label mb-0">User</label>
                                            </div>
                                         <div class="col-7 col-md-7">
                                                <select asp-for="InvoiceType" class="form-select form-select-sm">
                                                    <option value="1">Abel Abraham</option>
                                                    <option value="2">Admin</option>
                                                    <option value="3">Simon Tolu</option>
                                                    <option value="4">liya Adam</option>
                                                </select>
                                            </div>
                                    </div>
                                </div>
                            </div>
                                <div class="card mb-3">
                                    <div class="card-header bg-info bg-opacity-25 fw-bold">Summary</div>
                                    <div class="card-body p-3">
                                        <div class="row mb-2 align-items-center">
                                            <div class="col-6">
                                                <label class="form-label">Subtotal</label>
                                            </div>
                                            <div class="col-6">
                                                <input asp-for="InvoiceAdditionalCharge" style="width:100%" type="number" step="0.01" class="form-control form-control-sm bg-info bg-opacity-25 text-end" value="0.00" />
                                            </div>
                                        </div>
                                        <div class="row mb-2 align-items-center">
                                            <div class="col-6">
                                                <label class="form-label">Tax</label>
                                            </div>
                                            <div class="col-6">
                                                <input asp-for="InvoiceTax" style="width:100%" type="number" step="0.01" class="form-control form-control-sm bg-info bg-opacity-25 text-end" value="0.00" />
                                            </div>
                                        </div>
                                        <div class="row mb-2 align-items-center">
                                            <div class="col-6">
                                                <label class="form-label">Additional Charge</label>
                                            </div>
                                            <div class="col-6">
                                                <input asp-for="InvoiceAdditionalCharge" style="width:100%" type="number" step="0.01" class="form-control form-control-sm bg-info bg-opacity-25 text-end" value="0.00" />
                                            </div>
                                        </div>
                                        <div class="row mb-2 align-items-center">
                                            <div class="col-6">
                                                <label class="form-label">Grand Total</label>
                                            </div>
                                            <div class="col-6">
                                                <input asp-for="InvoiceTotal" type="number" style="width:100%" step="0.01" class="form-control form-control-sm bg-info bg-opacity-25 text-end" value="0.00" />
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        </div>
                         <div class="d-grid gap-2 mt-4">
                      <!-- Submit and Clear buttons moved to top -->
                     </form>
                       </div>
                     </div>
             </div>
         </div>
  </div>